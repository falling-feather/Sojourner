                { "op": "addStat", "stat": "career", "value": 6 },
                { "op": "addStat", "stat": "support", "value": 4 },
                { "op": "addStat", "stat": "stress", "value": -4 },
                { "op": "addTag", "tag": "技能线" }
              ],
              "next": { "kind": "stage", "stageId": "youth_hs", "sceneId": "youth_fork" }
            }
          ]
        }
      ]
    },
    {
      "id": "youth_hs",
      "title": "初高中",
      "scenes": [
        {
          "id": "youth_fork",
          "narrative": [
            "倒计时牌翻得比日历快。有人把青春过成试卷，也有人把试卷折成纸飞机。",
            "你隐约知道：接下来几年会决定很多「后来」。"
          ],
          "choices": [
            {
              "id": "y_gaokao",
              "label": "以高考为主轴，别的先让路",
              "effects": [
                { "op": "addStat", "stat": "career", "value": 8 },
                { "op": "addStat", "stat": "stress", "value": 12 }
              ],
              "next": { "kind": "stage", "stageId": "highPressure", "sceneId": "high_night" }
            },
            {
              "id": "y_life",
              "label": "保留生活：恋爱、爱好、身体都不放弃",
              "effects": [
                { "op": "addStat", "stat": "support", "value": 10 },
                { "op": "addStat", "stat": "stress", "value": -6 },
                { "op": "addStat", "stat": "career", "value": 3 }
              ],
              "next": { "kind": "stage", "stageId": "highPressure", "sceneId": "high_night" }
            }
          ]
        }
      ]
    },
    {
      "id": "highPressure",
      "title": "高三",
      "scenes": [
        {
          "id": "high_night",
          "narrative": [
            "深夜台灯下，试卷、排名、父母的沉默叠成薄被。",
            "你反复权衡：再刷一套，还是让身体先投降？"
          ],
          "choices": [
            {
              "id": "grind_late",
              "label": "再熬一小时，把错题啃完",
              "effects": [
                { "op": "addStat", "stat": "career", "value": 10 },
                { "op": "addStat", "stat": "stress", "value": 14 },
                { "op": "addStat", "stat": "healthDebt", "value": 8 },
                { "op": "addTag", "tag": "熬夜" }
              ],
              "next": { "kind": "stage", "stageId": "gaokao", "sceneId": "gk_before" }
            },
            {
              "id": "rest_ok",
              "label": "准时睡，相信白天的效率",
              "effects": [
                { "op": "addStat", "stat": "career", "value": 5 },
                { "op": "addStat", "stat": "stress", "value": -6 },
                { "op": "addStat", "stat": "support", "value": 5 }
              ],
              "next": { "kind": "stage", "stageId": "gaokao", "sceneId": "gk_before" }
            }
          ]
        }
      ]
    },
    {
      "id": "gaokao",
      "title": "高考",
      "scenes": [
        {
          "id": "gk_before",
          "narrative": [
            "铃声像仪式。你摸着准考证的塑封边，想起小学那块橡皮。",
            "努力把概率推向你，但人生仍保留「发挥」这个词。"
