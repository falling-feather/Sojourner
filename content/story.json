            "走廊变长，科目变多。你开始理解「分流」不是新闻里的词，而是身边的座位变化。",
            "青春期像耳鸣：友谊、排名、暗恋与自我怀疑同时放大。"
          ],
          "choices": [
            {
              "id": "ms_key",
              "label": "进重点班，冲升学率",
              "effects": [
                { "op": "addStat", "stat": "career", "value": 12 },
                { "op": "addStat", "stat": "stress", "value": 10 }
              ],
              "next": { "kind": "stage", "stageId": "youth_hs", "sceneId": "youth_fork" }
            },
            {
              "id": "ms_norm",
              "label": "留在普通班，保留喘息",
              "effects": [
                { "op": "addStat", "stat": "support", "value": 6 },
                { "op": "addStat", "stat": "career", "value": 6 }
              ],
              "next": { "kind": "stage", "stageId": "youth_hs", "sceneId": "youth_fork" }
            },
            {
              "id": "ms_art",
              "label": "走特长：艺术/体育试一试",
              "effects": [{ "op": "addStat", "stat": "luck", "value": 8 }],
              "next": { "kind": "stage", "stageId": "youth_hs", "sceneId": "youth_fork" }
            }
          ]
        }
      ]
    },
    {
