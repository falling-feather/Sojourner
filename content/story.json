              "next": { "kind": "stage", "stageId": "middle", "sceneId": "ms_fork" }
            },
            {
              "id": "pri_wide",
              "label": "多试兴趣，少盯分数",
              "effects": [
                { "op": "addStat", "stat": "support", "value": 10 },
                { "op": "addStat", "stat": "career", "value": 4 }
              ],
              "next": { "kind": "stage", "stageId": "middle", "sceneId": "ms_fork" }
            },
            {
              "id": "pri_balance",
              "label": "在成绩与玩耍之间找平衡",
              "effects": [
                { "op": "addStat", "stat": "career", "value": 6 },
                { "op": "addStat", "stat": "support", "value": 5 },
                { "op": "addStat", "stat": "stress", "value": 2 }
              ],
              "next": { "kind": "stage", "stageId": "middle", "sceneId": "ms_fork" }
            }
          ]
        }
      ]
    },
