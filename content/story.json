          "choices": [
            {
              "id": "gk_enter",
              "label": "走进考场，完成这场检定",
              "check": {
                "kind": "threshold",
                "id": "gaokao_main",
                "label": "高考发挥",
                "modifiers": {
                  "addStatWeights": [{ "stat": "career", "weight": 0.3 }],
                  "luckWeight": 0.12,
                  "stressPenalty": 0.2
                },
                "bands": [
                  {
                    "min": 0,
                    "max": 28,
                    "label": "失常",
                    "next": { "kind": "scene", "sceneId": "gk_rl" },
                    "effects": [
                      { "op": "setFlag", "key": "gk_tier", "value": false },
                      { "op": "addStat", "stat": "stress", "value": 16 }
                    ]
                  },
                  {
                    "min": 29,
                    "max": 72,
                    "label": "正常发挥",
                    "next": { "kind": "scene", "sceneId": "gk_rm" },
                    "effects": [{ "op": "setFlag", "key": "gk_tier", "value": true }]
