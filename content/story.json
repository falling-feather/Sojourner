                  {
                    "min": 73,
                    "max": 100,
                    "label": "超常发挥",
                    "next": { "kind": "scene", "sceneId": "gk_rh" },
                    "effects": [
                      { "op": "setFlag", "key": "gk_tier", "value": true },
                      { "op": "addStat", "stat": "career", "value": 10 },
                      { "op": "addStat", "stat": "luck", "value": 6 }
                    ]
                  }
                ]
              }
            }
          ]
        },
        {
          "id": "gk_rl",
          "narrative": [
            "成绩出来那天，走廊的风有点凉。名次像轻轻推了一下腰。",
            "路没有断，只是拐弯更急。"
          ],
          "choices": [
            {
              "id": "from_rl",
              "label": "收拾情绪，去读大学",
              "effects": [
                { "op": "addStat", "stat": "career", "value": 4 },
                { "op": "addStat", "stat": "stress", "value": 6 }
              ],
              "next": { "kind": "stage", "stageId": "university", "sceneId": "uni_y1" }
            }
          ]
        },
        {
          "id": "gk_rm",
          "narrative": [
            "分数与预期大致握手言和。填志愿像拼一张并不完美的地图。",
            "大学城的梧桐、社团与熬夜的论文在等你。"
          ],
          "choices": [
            {
              "id": "from_rm",
              "label": "带着平常心报到",
              "effects": [{ "op": "addStat", "stat": "career", "value": 8 }],
              "next": { "kind": "stage", "stageId": "university", "sceneId": "uni_y1" }
            }
          ]
        },
        {
          "id": "gk_rh",
          "narrative": [
            "榜单上你的名字像意外亮起的灯。更好的平台不会替你走路，但会给你更多选择。",
            "比较与期待也会一同升级。"
          ],
          "choices": [
            {
              "id": "from_rh",
              "label": "把幸运当成责任，去报到",
              "effects": [
                { "op": "addStat", "stat": "career", "value": 12 },
                { "op": "addStat", "stat": "stress", "value": 4 }
