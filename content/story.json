            {
              "id": "ms_norm",
              "label": "留在普通班，保留喘息",
              "effects": [
                { "op": "addStat", "stat": "support", "value": 6 },
                { "op": "addStat", "stat": "career", "value": 6 }
              ],
              "next": { "kind": "stage", "stageId": "youth_hs", "sceneId": "youth_fork" }
            },
            {
              "id": "ms_art",
              "label": "走特长：艺术/体育试一试",
              "effects": [{ "op": "addStat", "stat": "luck", "value": 8 }],
