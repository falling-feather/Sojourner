  "stages": [
    {
      "id": "birth",
      "title": "诞生",
      "scenes": [
        {
          "id": "birth_hello",
          "narrative": [
            "啼哭与光亮同时抵达。名字被轻声念出，像一枚尚未盖章的印章。",
            "世界很大，而你从一声呼吸开始计时。"
          ],
          "choices": [
            {
              "id": "birth_flow",
              "label": "时间开始向前流动",
              "next": { "kind": "stage", "stageId": "childhood", "sceneId": "child_play" }
            }
          ]
        }
      ]
    },
    {
      "id": "childhood",
      "title": "幼年",
      "scenes": [
        {
          "id": "child_play",
          "narrative": [
            "积木搭高又倒塌；大人说「要乖」，你只看见窗帘像慢吞吞的海。",
            "第一次意识到：日子会重复，但每一次重复都略略不同。"
          ],
          "choices": [
            {
              "id": "child_school",
              "label": "进入学龄前记忆，准备上学",
              "effects": [{ "op": "addStat", "stat": "support", "value": 4 }],
              "next": { "kind": "stage", "stageId": "primary", "sceneId": "pri_school" }
            }
          ]
        }
      ]
    },
    {
      "id": "primary",
      "title": "小学",
      "scenes": [
        {
          "id": "pri_school",
          "narrative": [
            "红领巾、课间操、橡皮屑。成绩像一串忽上忽下的台阶。",
            "「别人家的孩子」不是一种生物，而是一种天气。"
          ],
          "choices": [
            {
              "id": "pri_focus",
              "label": "盯紧主科，把基础打牢",
              "effects": [
                { "op": "addStat", "stat": "career", "value": 8 },
                { "op": "addStat", "stat": "stress", "value": 5 }
