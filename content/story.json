          "choices": [
            {
              "id": "gk_enter",
              "label": "走进考场，完成这场检定",
              "check": {
                "kind": "threshold",
                "id": "gaokao_main",
                "label": "高考发挥",
                "modifiers": {
                  "addStatWeights": [{ "stat": "career", "weight": 0.3 }],
                  "luckWeight": 0.12,
                  "stressPenalty": 0.2
                },
                "bands": [
                  {
                    "min": 0,
                    "max": 28,
                    "label": "失常",
                    "next": { "kind": "scene", "sceneId": "gk_rl" },
